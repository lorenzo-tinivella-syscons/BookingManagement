<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<schema xmlns="http://www.w3.org/2001/XMLSchema" xmlns:tns="http://www.example.org/BookingSchema" elementFormDefault="qualified" targetNamespace="http://www.example.org/BookingSchema">
      
  
